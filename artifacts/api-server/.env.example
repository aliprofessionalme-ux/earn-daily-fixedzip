PORT=8080
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ADMIN_PASSWORD=
SESSION_SECRET=

# Public backend URL used for provider callback URLs.
# Example: https://your-replit-domain.replit.app
PUBLIC_BASE_URL=

# CORS
ALLOWED_ORIGINS=

# Provider secrets (webhook validation, keep these server-side only)
MONLIX_API_SECRET=
MONLIX_SECRET=
TAPJOY_SECRET_KEY=
AYET_ACCOUNT_ID=
AYET_PLACEMENT_ID=
AYET_ADSLOT_ID=
AYET_ADSLOT_NAME=
AYET_ANDROID_PACKAGE=com.earndaily.app
AYET_API_KEY=
AYET_POSTBACK_SECRET=
PUBSCALE_API_KEY=

# Provider app IDs / public launch values (safe to expose through settings)
MONLIX_APP_ID=
TAPJOY_APP_ID=
TAPJOY_SDK_KEY=
TAPJOY_WEB_SDK_KEY=
PUBSCALE_APP_ID=

# Optional offerwall launch URL templates.
# Put {deviceId} where the user/device identifier should go.
# If your provider dashboard gives a different web launch URL, paste it here.
MONLIX_OFFERWALL_URL_TEMPLATE=
TAPJOY_OFFERWALL_URL_TEMPLATE=
AYET_OFFERWALL_URL_TEMPLATE=
PUBSCALE_OFFERWALL_URL_TEMPLATE=

# Coin conversion rates (coins per 1 USD)
MONLIX_COINS_PER_USD=5000
TAPJOY_COINS_PER_USD=5000
AYET_COINS_PER_USD=5000
AYET_USD_TO_COINS=5000
PUBSCALE_COINS_PER_USD=5000

# Large reward threshold for manual review
LARGE_REWARD_MANUAL_REVIEW_USD=5

# Hold periods (days)
NORMAL_HOLD_DAYS=7
NEW_USER_HOLD_DAYS=14

# Task slot system
FREE_TASK_SLOTS=3
ENERGY_PER_EXTRA_SLOT=5
MAX_EXTRA_SLOTS=3

# Unity interstitial gate after 5 spins + 5 scratches.
# Rewarded energy still needs native SDK + server-side verification before it can give Energy safely.
UNITY_ANDROID_GAME_ID=800000310
UNITY_INTERSTITIAL_PLACEMENT_ID=Interstitial_Android
UNITY_REWARDED_PLACEMENT_ID=Rewarded_Android
UNITY_BANNER_PLACEMENT_ID=Banner_Android
UNITY_SERVER_SIDE_VERIFICATION_SECRET=
UNITY_TEST_MODE=true
