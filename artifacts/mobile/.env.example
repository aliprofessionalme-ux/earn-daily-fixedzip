# Provider secrets and app IDs stay on the backend. Mobile receives safe launch status from /api/settings.
# Add EXPO_PUBLIC_* provider IDs only if a future native SDK explicitly requires a public non-secret ID.

# Unity public IDs for future native SDK builds only. Reward buttons stay disabled until verified callbacks are implemented.
EXPO_PUBLIC_UNITY_ANDROID_GAME_ID=800000310
EXPO_PUBLIC_UNITY_REWARDED_PLACEMENT_ID=Rewarded_Android
